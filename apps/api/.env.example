DATABASE_URL="postgresql://questly:questly@localhost:5433/questly?schema=public"
REDIS_URL="redis://localhost:6379"
JWT_SECRET="dev-only-secret-change-me"
JWT_ACCESS_TTL="15m"

# Shared secret for POST/GET /api/v1/agent/* (external integrations, e.g. a
# Zapier AI Agent) — sent as the X-Api-Key header. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AGENT_API_KEY=""

# Optional — Nova (the built-in AI assistant) falls back to a "not
# configured" message when this is unset, rather than failing to boot.
ANTHROPIC_API_KEY=""

# Optional — set to "ollama" to run Nova on a free local model via Ollama
# (https://ollama.com) instead of the Anthropic API. Leave unset to keep
# using ANTHROPIC_API_KEY above. See OLLAMA_BASE_URL/OLLAMA_MODEL below.
AI_PROVIDER=""

# Only used when AI_PROVIDER=ollama. Defaults shown — override only if
# Ollama runs on a different host/port, or you pulled a different model:
#   ollama pull llama3.2
# OLLAMA_BASE_URL="http://localhost:11434"
# OLLAMA_MODEL="llama3.2"
