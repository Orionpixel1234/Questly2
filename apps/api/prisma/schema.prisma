// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider     = "prisma-client"
  // Under src/, not a sibling of it — a sibling would sit outside
  // tsconfig's rootDir and break `nest build`'s output layout.
  output       = "../src/generated/prisma"
  // The rest of this NestJS app (Jest, `nest build`) is CommonJS; without
  // this the generator defaults to ESM output and every consumer breaks
  // with "exports is not defined in ES module scope".
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// Fixed set of the four panel roles from the onboarding questionnaire.
// A model (not an enum) so future permission/role metadata has somewhere to live.
model Role {
  id    String @id @default(cuid())
  name  String @unique
  users User[]
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  roleId       String
  role         Role     @relation(fields: [roleId], references: [id])
  subjects     String[]
  degreeTrack  String?
  // 'studying' | 'teaching' from the onboarding questionnaire — validated
  // at the API layer (class-validator), not a DB enum, to match how
  // `subjects` is already free text rather than a foreign key.
  goalType     String?
  // Admin moderation. Checked at login and token refresh (see AuthService) —
  // not at every JwtStrategy.validate, so a banned user's already-issued
  // access token stays valid until it expires (max JWT_ACCESS_TTL, 15m default).
  banned       Boolean  @default(false)
  bannedReason String?
  goals        Goal[]
  lessons      Lesson[]
  classes      Class[]
  enrollments  Enrollment[]
  completions  LessonCompletion[]
  calendarEvents CalendarEvent[]
  gameProfile  GameProfile?
  agentLogs    AgentActivityLog[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Per-subject targets chosen at signup, now also the live EXP ledger for
// that subject (see LessonCompletion — completing a lesson increments the
// matching Goal.exp, auto-creating one with a default target if the
// student never explicitly set a goal for that subject).
model Goal {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  subject   String
  target    Int
  exp       Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([userId, subject])
}

// One row per (student, lesson) they've marked complete — the gate that
// makes "mark complete" idempotent (completing the same lesson twice
// shouldn't double-award EXP).
model LessonCompletion {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  lessonId    String
  lesson      Lesson   @relation(fields: [lessonId], references: [id])
  expAwarded  Int
  completedAt DateTime @default(now())

  @@unique([userId, lessonId])
}

// DRAFT: author/educator still editing, invisible to everyone else.
// PENDING_REVIEW: submitted, waiting on an admin.
// PUBLISHED: approved, visible in the catalog and completable.
// REJECTED: admin declined it (see rejectionNote); author can edit and resubmit.
enum LessonStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  REJECTED
}

model Lesson {
  id          String       @id @default(cuid())
  title       String
  description String
  subject     String
  // LessonML source — see LESSON_DSL.md at the repo root for the grammar.
  content     String       @default("")
  status      LessonStatus @default(DRAFT)
  rejectionNote String?
  authorId    String
  author      User         @relation(fields: [authorId], references: [id])
  completions LessonCompletion[]
  agentLogs   AgentActivityLog[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Class {
  id             String          @id @default(cuid())
  name           String
  subject        String
  educatorId     String
  educator       User            @relation(fields: [educatorId], references: [id])
  enrollments    Enrollment[]
  calendarEvents CalendarEvent[]
  createdAt      DateTime        @default(now())
}

// A personal calendar entry — "arrange your preferred classes in a neat
// organized calendar" from the product brief. Scoped to the owning user,
// not shared/global; optionally linked to a Class for context (which
// subject/educator it's for) but the schedule itself is per-student.
model CalendarEvent {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  subject   String?
  classId   String?
  class     Class?   @relation(fields: [classId], references: [id])
  startTime DateTime
  endTime   DateTime
  createdAt DateTime @default(now())
}

// The "game" layer — deliberately has no data of its own beyond a currency
// and a cosmetic tier. Its map (which systems/nodes exist, which are
// claimed) is always derived live from real Lesson/LessonCompletion rows
// (see GameService.starMap), so there's nothing here to fake progress with.
model GameProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  stardust  Int      @default(0)
  shipTier  Int      @default(1)
  updatedAt DateTime @updatedAt
}

enum AgentEventStatus {
  IN_PROGRESS
  COMPLETED
}

// Audit trail for POST /api/v1/agent/progress (external agents, e.g. a
// Zapier AI Agent running a tutoring conversation against a lesson). Every
// call is logged here regardless of outcome; a COMPLETED event additionally
// drives the real completion path (ProgressService.completeLesson) so EXP
// and Stardust go through the exact same rules as an in-app completion —
// this table itself never awards anything on its own.
model AgentActivityLog {
  id              String           @id @default(cuid())
  userId          String
  user            User             @relation(fields: [userId], references: [id])
  lessonId        String
  lesson          Lesson           @relation(fields: [lessonId], references: [id])
  status          AgentEventStatus
  userResponses   Json?
  metadata        Json?
  clientTimestamp DateTime?
  createdAt       DateTime         @default(now())
}

model Enrollment {
  id        String   @id @default(cuid())
  classId   String
  class     Class    @relation(fields: [classId], references: [id])
  studentId String
  student   User     @relation(fields: [studentId], references: [id])
  createdAt DateTime @default(now())

  @@unique([classId, studentId])
}
